#!/usr/bin/env python3

import subprocess
import shlex
import sys
import os
import fnmatch
import re
import argparse
import json
import tempfile

def run(*args, **kwargs):
	def run_args_gen():
		for a in args:
			if isinstance(a, list):
				yield from a
			else:
				yield from shlex.split(a)
	run_args = list(run_args_gen())
	try:
		return subprocess.run(run_args, check=True, text=True, capture_output=True, **kwargs).stdout
	except subprocess.CalledProcessError as exc:
		eprint(exc.stderr)
		raise

def strip_remote(b):
	return b[b.index('/')+1:]

def eprint(*args, **kwargs):
	kwargs.setdefault('file', sys.stderr)
	kwargs.setdefault('flush', True)
	return print(*args, **kwargs)

def parse_semver(tag):
	"""Parse a semver tag (with optional 'v' prefix). Returns (major, minor, patch, pre) or None."""
	m = re.match(r'^v?(\d+)\.(\d+)\.(\d+)(-(.*))?$', tag)
	if m:
		return int(m.group(1)), int(m.group(2)), int(m.group(3)), m.group(5) or ''
	return None

def go_version_to_git_ref(go_version):
	"""For pseudo-versions, return the abbreviated commit hash. Otherwise return the version as a git tag ref."""
	parts = go_version.split('-')
	if len(parts) == 3:
		h = parts[2]
		if len(h) == 12 and all(c in '0123456789abcdef' for c in h):
			return h
	return go_version

def semver_sort_key(sv):
	major, minor, patch, pre = sv
	# Pre-releases sort before the final release (0 < 1)
	return (major, minor, patch, 0 if pre else 1, pre)

def main():
	parser = argparse.ArgumentParser(description='Tag downstream repo references in the current torrent repo')
	parser.add_argument('downstream_path', help='Path to downstream git repo')
	parser.add_argument('downstream_name', help='Name used in tag prefix (e.g. erigon)')
	parser.add_argument('module', nargs='?', default=None,
		help='Go module path to look up in the downstream (default: derived from current directory go.mod)')
	parser.add_argument('--branch-pattern', default='main master release/*',
		help='Space-separated glob patterns for remote branch short names to include (default: "main master release/*")')
	parser.add_argument('--tag-pattern', default='v*',
		help='Glob pattern for tags to include (default: "v*")')
	parser.add_argument('--no-fetch', action='store_true',
		help='Skip fetching from origin')
	parser.add_argument('--debug', action='store_true',
		help='Show go.mod reads as they occur')
	parser.add_argument('--no-prune-stale', dest='prune_stale', action='store_false',
		help='Keep downstream tags not emitted in this run')
	parser.set_defaults(prune_stale=True)
	args = parser.parse_args()

	git_dir = args.downstream_path
	downstream_name = args.downstream_name
	module = args.module
	if module is None:
		module = run('go list -m').strip()
	branch_patterns = args.branch_pattern.split()
	tag_pattern = args.tag_pattern

	def filter_branch(b):
		return any(fnmatch.fnmatch(b, pat) for pat in branch_patterns)

	def tag_filter(tag):
		return fnmatch.fnmatch(tag, tag_pattern)

	def git_in_tree(*a):
		return run('git -C', git_dir, *a)

	if not args.no_fetch:
		eprint(f'fetching {git_dir}...')
		git_in_tree('fetch origin')

	raw_branches = git_in_tree("for-each-ref refs/remotes/origin --format='%(refname:short)'").splitlines()
	all_tags = list(filter(tag_filter, git_in_tree("for-each-ref refs/tags --format='%(refname:short)'").splitlines()))

	def fetch_module_version(treeish):
		"""Returns (go_version, None) on success or (None, reason) on failure."""
		if args.debug:
			eprint(f'  reading go.mod from {treeish}')
		try:
			gomod_content = subprocess.run(
				['git', '-C', git_dir, 'show', f'{treeish}:go.mod'],
				check=True, text=True, capture_output=True).stdout
		except subprocess.CalledProcessError:
			return None, 'no go.mod'
		with tempfile.NamedTemporaryFile(mode='w', suffix='.mod', delete=False) as f:
			f.write(gomod_content)
			tmp_path = f.name
		try:
			result = subprocess.run(['go', 'mod', 'edit', '-json', tmp_path],
				check=True, text=True, capture_output=True)
			mod_data = json.loads(result.stdout)
		except subprocess.CalledProcessError as exc:
			first_line = exc.stderr.strip().splitlines()[0] if exc.stderr.strip() else '(no output)'
			return None, first_line
		finally:
			os.unlink(tmp_path)
		# Check Replace entries first
		for rep in mod_data.get('Replace') or []:
			if rep['Old']['Path'] == module:
				new = rep['New']
				if new.get('Version'):
					return new['Version'], None
				# Local path replace — fall through to Require
				break
		# Look in Require
		for req in mod_data.get('Require') or []:
			if req['Path'] == module:
				return req['Version'], None
		return None, f'{module} not in go.mod'

	# Collect branch refs
	branch_refs = []  # (nice_name, commit)
	eprint(f'\nbranches (pattern: {args.branch_pattern}):')
	for rtb in raw_branches:
		try:
			rb = strip_remote(rtb)
		except ValueError:
			if args.debug:
				eprint(f'  skipping {rtb}: no slash in ref name')
			continue
		if not filter_branch(rb):
			continue
		go_version, reason = fetch_module_version(rtb)
		if go_version is None:
			eprint(f'  {rb}: skipped: {reason}')
		else:
			eprint(f'  {rb}: {go_version}')
			branch_refs.append((rb, go_version))

	# Only process semver tags; others (vv*, 4-component, etc.) are silently skipped
	semver_tags = sorted(
		[(tag, sv) for tag in all_tags if (sv := parse_semver(tag)) is not None],
		key=lambda x: semver_sort_key(x[1]))

	def flush_range(start, end, msg):
		if start == end:
			eprint(f'  {start}: {msg}')
		else:
			eprint(f'  [{start}, {end}]: {msg}')

	to_create = []
	for rb, go_version in branch_refs:
		to_create.append((f'downstreams/{downstream_name}/branch/{rb}', go_version, go_version_to_git_ref(go_version)))

	# Walk semver tags in order. Only create a downstream tag when the upstream ref changes.
	last_semver_go_version = None
	eprint(f'\ntags:')
	range_start = range_end = range_msg = None
	for tag, sv in semver_tags:
		go_version, reason = fetch_module_version(tag)
		if go_version is None:
			msg = f'skipped: {reason}'
		else:
			msg = go_version
			if go_version != last_semver_go_version:
				last_semver_go_version = go_version
				to_create.append((f'downstreams/{downstream_name}/{tag}', go_version, go_version_to_git_ref(go_version)))
		if args.debug:
			eprint(f'  {tag}: {msg}')
		if msg == range_msg:
			range_end = tag
		else:
			if range_start is not None:
				flush_range(range_start, range_end, range_msg)
			range_start = range_end = tag
			range_msg = msg
	if range_start is not None:
		flush_range(range_start, range_end, range_msg)

	eprint('\ntags to create:')
	for tag_name, go_version, git_ref in to_create:
		eprint(f'  {tag_name} -> {go_version}')

	prefix = f'downstreams/{downstream_name}/'
	emitted = {tag_name for tag_name, _, _ in to_create}

	eprint()
	for tag_name, go_version, git_ref in to_create:
		ref_desc = f' ({git_ref})' if git_ref != go_version else ''
		existing = subprocess.run(
			['git', 'rev-parse', f'refs/tags/{tag_name}^{{}}'],
			text=True, capture_output=True)
		if existing.returncode == 0:
			existing_commit = existing.stdout.strip()
			target = subprocess.run(
				['git', 'rev-parse', f'{git_ref}^{{}}'],
				text=True, capture_output=True)
			if target.returncode != 0:
				eprint(f'warning: {tag_name}: cannot resolve {go_version}{ref_desc}, skipping')
				continue
			if existing_commit == target.stdout.strip():
				continue
			eprint(f'error: {tag_name} already points to {existing_commit[:12]}, wanted {go_version}{ref_desc}')
			sys.exit(1)
		result = subprocess.run(['git', 'tag', tag_name, git_ref], text=True, capture_output=True)
		if result.returncode != 0:
			eprint(f'warning: {tag_name}: cannot resolve {go_version}{ref_desc}, skipping')
		else:
			print(tag_name, '->', go_version)

	if args.prune_stale:
		stale = [t for t in run('git tag -l').splitlines() if t.startswith(prefix) and t not in emitted]
		for tag_name in stale:
			commit = subprocess.run(['git', 'rev-parse', f'refs/tags/{tag_name}^{{}}'],
				text=True, capture_output=True).stdout.strip()
			run(['git', 'tag', '-d', tag_name])
			print(f'pruned {tag_name} -> {commit[:12]}')

main()
